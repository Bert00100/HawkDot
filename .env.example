# ==========================================================
# HawkDot — MODELO de variáveis de ambiente
# Copie este arquivo para .env e preencha com valores reais:
#   cp .env.example .env
# NÃO coloque senhas reais aqui — este arquivo VAI pro Git.
# ==========================================================

# --- Banco de dados (PostgreSQL) ---
POSTGRES_USER=hawkdot
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=hawkdot_db
POSTGRES_PORT=5432

# Versão da imagem do Postgres usada no docker-compose
POSTGRES_VERSION=17

# --- Painel (backend Node.js) ---
PANEL_PORT=3000
